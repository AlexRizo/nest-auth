generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRoleEnum {
  ADMIN
  STAFF
  CLIENT_ADMIN
  CLIENT_STAFF
  CLIENT
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  username String  @unique
  avatar   String?
  password String? // null para usuarios que solo usan OAuth

  // 2FA (TOTP via otplib)
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  // Estado de la cuenta
  emailVerified Boolean        @default(false)
  status        UserStatusEnum @default(ACTIVE)
  role          UserRoleEnum   @default(CLIENT)

  fullAccess Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  authProvider AuthProviderEnum @default(LOCAL)

  sessions     Session[]
  accessGrants AccessGrant[]
}

enum AuthProviderEnum {
  LOCAL
  GOOGLE
}

enum UserStatusEnum {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

model Session {
  id String @id @default(uuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String

  userAgent String?
  ipAddress String?
  location  String?

  isActive Boolean @default(true)

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, ipAddress, userAgent])
}

enum AccessScopeEnum {
  WORKSPACE
  SPACE
}

model Workspace {
  id    String @id @default(uuid())
  name  String
  code  String @unique
  color String

  createdAt DateTime @default(now())

  workspaceGrants AccessGrant[]
  spaces          Space[]
}

model Space {
  id    String @id @default(uuid())
  name  String
  code  String @unique
  color String

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  spaceGrants AccessGrant[]
}

model AccessGrant {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scope AccessScopeEnum

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  spaceId String?
  space   Space?  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, workspaceId])
  @@unique([userId, spaceId])
}
